    <main id="main">
        <section class="section section-light feedback-section">
            <div class="container feedback-container">
                <div class="section-header">
                    <h2>Patient Experience Feedback</h2>
                    <p>Your feedback helps us provide the highest standard of homeopathic care. Please share your experience with Dr. Kokhila and our clinic.</p>
                </div>

                <div class="feedback-form-wrapper">
                    <!-- Sending form data to drkok2000@gmail.com via formsubmit.co -->
                    <form action="https://formsubmit.co/drkok2000@gmail.com" method="POST" class="feedback-form">
                        
                        <!-- FormSubmit Configurations -->
                        <input type="hidden" name="_subject" value="New Patient Feedback!">
                        <input type="hidden" name="_template" value="table">
                        <input type="hidden" name="_captcha" value="false">

                        <div class="form-group">
                            <label for="patientName">Patient Name:</label>
                            <input type="text" id="patientName" name="Patient_Name" required placeholder="Enter your full name">
                        </div>

                        <div class="form-group">
                            <label>Did the doctor explain your condition (disease) clearly?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Explained_Condition" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Explained_Condition" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Explained_Condition" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Did the doctor explain the treatment plan to you?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Explained_Treatment" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Explained_Treatment" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Explained_Treatment" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Did the doctor suggest an appropriate diet plan?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Suggested_Diet" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Suggested_Diet" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Suggested_Diet" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Was the doctor attentive to your concerns and questions?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Attentive_To_Concerns" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Attentive_To_Concerns" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Attentive_To_Concerns" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Was the doctor’s explanation easy to understand?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Easy_To_Understand" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Easy_To_Understand" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Easy_To_Understand" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Did you feel comfortable during the consultation?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Felt_Comfortable" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Felt_Comfortable" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Felt_Comfortable" value="Somewhat"> <span>Somewhat</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Would you recommend this doctor to others?</label>
                            <div class="rating-group">
                                <label class="rating-label"><input type="radio" name="Recommend_Doctor" value="Yes" required> <span>Yes</span></label>
                                <label class="rating-label"><input type="radio" name="Recommend_Doctor" value="No"> <span>No</span></label>
                                <label class="rating-label"><input type="radio" name="Recommend_Doctor" value="Maybe"> <span>Maybe</span></label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="comments">Any additional comments or suggestions for improvement?</label>
                            <textarea id="comments" name="Additional_Comments" rows="5" placeholder="Share your detailed feedback here..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary submit-btn">
                            <i class="fas fa-paper-plane"></i> Submit Feedback
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2025 <a href="index.html">Noble Homoeopathy Clinic</a>. All rights reserved. | Chennai, Tamil Nadu, India</p>
        </div>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secure Patient Tracker - Noble Homoeopathy</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: var(--gradient-hero); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .tracker-container { width: 90%; max-width: 600px; background: var(--white); border-radius: var(--radius-xl); padding: 40px; box-shadow: var(--shadow-xl); position: relative; overflow: hidden; }
        .hidden { display: none !important; }
        .tracker-header { text-align: center; margin-bottom: 30px; }
        .tracker-header i { font-size: 3rem; color: var(--primary); margin-bottom: 15px; }
        .form-group { margin-bottom: 20px; text-align: left; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--navy); }
        .form-control { width: 100%; padding: 12px 16px; border: 1px solid var(--slate-light); border-radius: var(--radius-md); font-family: inherit; font-size: 1rem; }
        .history-data { margin-top: 30px; background: var(--lighter); padding: 20px; border-radius: var(--radius-md); border-left: 4px solid var(--accent); }
        .data-table-container { margin-top: 30px; overflow-x: auto; border: 1px solid var(--slate-light); border-radius: var(--radius-md); }
        .data-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .data-table th, .data-table td { padding: 12px 15px; text-align: left; border-bottom: 1px solid var(--slate-light); line-height: 1.4; }
        .data-table th { background: var(--lighter); font-weight: 700; color: var(--navy); white-space: nowrap; }
        .data-table tbody tr:hover { background: rgba(0, 163, 204, 0.05); }
        .data-table td { color: var(--body-text); }
        .search-box { width: 100%; padding: 12px 15px; border-radius: var(--radius-md); border: 1px solid var(--slate-light); margin-bottom: 15px; font-size: 0.95rem; transition: border-color 0.2s; }
        .search-box:focus { border-color: var(--primary); outline: none; }
        
        /* Modal UI */
        .patient-modal-overlay { position: fixed; inset: 0; background: rgba(10, 22, 40, 0.4); backdrop-filter: blur(8px); z-index: 10005; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: opacity 0.3s; }
        .patient-modal-overlay.active { opacity: 1; visibility: visible; }
        .patient-modal-card { background: var(--white); width: 95%; max-width: 600px; border-radius: var(--radius-xl); box-shadow: var(--shadow-xl); padding: 30px; position: relative; transform: translateY(20px); transition: transform 0.3s; max-height: 90vh; overflow-y: auto; text-align: left;}
        .patient-modal-overlay.active .patient-modal-card { transform: translateY(0); }
        .modal-close { position: absolute; top: 15px; right: 20px; font-size: 1.5rem; color: var(--slate); cursor: pointer; }
        .detail-row { display: flex; flex-direction: column; margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid var(--slate-light); }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { color: var(--slate); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 4px; }
        .detail-value { color: var(--navy); font-size: 1.05rem; }
        .data-table tbody tr { cursor: pointer; }
    </style>
</head>

<body>

    <div class="lang-switcher" style="position: absolute; top: 15px; right: 20px; z-index: 10;">
        <button class="lang-btn active" id="lang-en" data-lang="en" onclick="switchLanguage('en')">EN</button>
        <button class="lang-btn" id="lang-ta" data-lang="ta" onclick="switchLanguage('ta')">தமிழ்</button>
        <button class="lang-btn" id="lang-hi" data-lang="hi" onclick="switchLanguage('hi')">हिंदी</button>
    </div>

    <div class="tracker-container" id="login-view">
        <a href="/" style="position: absolute; top: 15px; left: 15px; color: var(--slate); font-size: 1.2rem;"><i class="fas fa-arrow-left"></i></a>
        <div class="tracker-header">
            <i class="fas fa-user-md"></i>
            <h2 data-i18n="tracker.loginTitle">Secure Portal</h2>
            <p style="color: var(--slate);" data-i18n="tracker.loginDesc">Restricted Access - Enter Credentials</p>
        </div>
        <form id="tracker-login-form">
            <div class="form-group">
                <label data-i18n="tracker.userid">User ID</label>
                <input type="text" id="userid" class="form-control" required placeholder="Authorized User ID">
            </div>
            <div class="form-group">
                <label data-i18n="tracker.password">Password</label>
                <input type="password" id="password" class="form-control" required placeholder="Secure Password">
            </div>
            <p id="login-error" style="color: red; display: none; margin-bottom: 15px; text-align: center; font-weight: bold;" data-i18n="tracker.invalid">Invalid Credentials</p>
            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;" data-i18n="tracker.authBtn">Authenticate</button>
        </form>
    </div>

    <div class="tracker-container hidden" id="dashboard-view" style="max-width: 800px;">
        <div class="tracker-header">
            <i class="fas fa-laptop-medical"></i>
            <h2 data-i18n="tracker.dashTitle">Patient History Tracker</h2>
            <p style="color: var(--slate);"><span data-i18n="tracker.session">Session Active: </span><span id="auth-name"></span></p>
            <a href="/" style="position: absolute; top: 15px; left: 15px; color: var(--slate); font-size: 1.5rem;"><i class="fas fa-arrow-left"></i></a>
        </div>
        
        <form id="patient-data-form">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label data-i18n="tracker.pid">Patient ID / File No.</label>
                    <input type="text" class="form-control" required>
                </div>
                <div class="form-group">
                    <label data-i18n="tracker.pname">Patient Full Name</label>
                    <input type="text" class="form-control" required>
                </div>
            </div>
            <div class="form-group">
                <label data-i18n="tracker.symptoms">Current Symptoms</label>
                <textarea class="form-control" rows="3" required></textarea>
            </div>
            <div class="form-group">
                <label data-i18n="tracker.medhistory">Medical History & Notes</label>
                <textarea class="form-control" rows="4"></textarea>
            </div>
            <button type="button" onclick="alert('Patient Data Logged Securely!')" class="btn btn-blue" style="width: 100%; justify-content: center;" data-i18n="tracker.submit">Submit Record to Database</button>
        </form>
        
        <div class="history-data">
            <h4 data-i18n="tracker.log">Recent Activity Log</h4>
            <p style="font-size: 0.9rem; color: var(--slate); margin-top: 10px;" data-i18n="tracker.logmsg">System Initialized.</p>
        </div>

        <hr style="margin: 40px 0; border: none; border-top: 1px dashed var(--slate-light);">
        
        <div class="tracker-header" style="text-align: left; margin-bottom: 15px;">
            <h3>Patient Records Database</h3>
            <p style="color: var(--slate); font-size: 0.9rem;">Loaded securely from cloud storage.</p>
        </div>

        <input type="text" id="patient-search" class="search-box" placeholder="Search by name, disease, or ID...">

        <div class="data-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Date</th>
                        <th>Patient Name</th>
                        <th>Diagnosis</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody id="patients-table-body">
                    <tr><td colspan="5" style="text-align: center; padding: 20px;">Fetching secure database...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Patient Modal Detail View -->
    <div id="patient-modal" class="patient-modal-overlay">
        <div class="patient-modal-card">
            <i class="fas fa-times modal-close" onclick="closePatientModal()"></i>
            <h2 id="modal-name" style="margin-bottom: 5px; color: var(--primary-dark);">Patient Name</h2>
            <p style="color: var(--slate); margin-bottom: 25px;"><i class="fas fa-hashtag"></i> <span id="modal-id"></span> &nbsp; • &nbsp; <i class="fas fa-calendar"></i> <span id="modal-date"></span></p>
            
            <div id="modal-details-container">
            </div>
            
            <button class="btn btn-outline" style="width: 100%; margin-top: 20px; justify-content: center;" onclick="closePatientModal()">Close Record</button>
        </div>
    </div>

    <!-- Inject JS for Translation Dictionary -->
    <script src="/script.js"></script>

    <script>
        document.getElementById('tracker-login-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const u = document.getElementById('userid').value;
            const p = document.getElementById('password').value;
            
            // Set loading state
            document.querySelector('#tracker-login-form button').innerText = "Authenticating...";
            
            try {
                const res = await fetch('/api/tracker-login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: u, password: p })
                });
                
                document.querySelector('#tracker-login-form button').innerText = "Authenticate";
                
                if(res.ok) {
                    const data = await res.json();
                    sessionStorage.setItem('trackerAuth', data.token); // Store secure token
                    document.getElementById('login-view').classList.add('hidden');
                    document.getElementById('dashboard-view').classList.remove('hidden');
                    document.getElementById('auth-name').innerText = data.user;
                    fetchPatientData(); // Load the database seamlessly
                } else {
                    document.getElementById('login-error').style.display = 'block';
                }
            } catch(err) {
                console.error(err);
                document.querySelector('#tracker-login-form button').innerText = "Authenticate";
                document.getElementById('login-error').innerText = "Connection Error";
                document.getElementById('login-error').style.display = 'block';
            }
        });

        // ── Data Loading Logic ──
        let memoryPatients = []; // Cached array for searching

        async function fetchPatientData() {
            const token = sessionStorage.getItem('trackerAuth');
            try {
                const res = await fetch('/api/patients-data', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(res.ok) {
                    const data = await res.json();
                    memoryPatients = data;
                    renderTable(data);
                } else {
                    document.getElementById('patients-table-body').innerHTML = '<tr><td colspan="6" style="color:red; text-align: center;">Error validating token.</td></tr>';
                }
            } catch (err) {
                console.error(err);
                document.getElementById('patients-table-body').innerHTML = '<tr><td colspan="6" style="color:red; text-align: center;">Connection lost to secure server.</td></tr>';
            }
        }

        function renderTable(dataArray) {
            const tbody = document.getElementById('patients-table-body');
            tbody.innerHTML = '';
            
            if(dataArray.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No patient records found in network.</td></tr>';
                return;
            }

            dataArray.forEach((p, idx) => {
                const tr = document.createElement('tr');
                tr.onclick = () => openPatientModal(idx, dataArray);
                tr.innerHTML = `
                    <td style="font-size: 0.85rem; color: var(--slate); font-weight: 600;">${p['Patient ID'] || ''}</td>
                    <td style="font-size: 0.85rem; color: var(--slate);">${p['Date'] || ''}</td>
                    <td style="font-weight: 600; color: var(--navy); white-space: nowrap;">${p['Patient Name'] || ''}</td>
                    <td><span style="background: rgba(0, 163, 204, 0.1); color: var(--primary-dark); padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; display: inline-block;">${p['Diagnosis'] || 'Check Notes'}</span></td>
                    <td style="font-size: 0.85rem; max-width: 250px;">${p['Treatment Notes'] || ''}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function openPatientModal(idx, dataArray) {
            const p = dataArray[idx];
            document.getElementById('modal-name').innerText = p['Patient Name'] || 'Unknown Patient';
            document.getElementById('modal-id').innerText = p['Patient ID'] || 'N/A';
            document.getElementById('modal-date').innerText = p['Date'] || 'N/A';
            
            const container = document.getElementById('modal-details-container');
            container.innerHTML = '';
            
            Object.keys(p).forEach(key => {
                if (key === 'Patient Name' || key === 'Patient ID' || key === 'Date') return; 
                if (!p[key] || p[key] === '') return; 
                
                container.innerHTML += `
                    <div class="detail-row">
                        <span class="detail-label">${key}</span>
                        <span class="detail-value">${p[key]}</span>
                    </div>
                `;
            });
            
            document.getElementById('patient-modal').classList.add('active');
        }

        function closePatientModal() {
            document.getElementById('patient-modal').classList.remove('active');
        }

        // ── Live Search Logic ──
        document.getElementById('patient-search').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            const filtered = memoryPatients.filter(p => Object.values(p).join(' ').toLowerCase().includes(term));
            renderTable(filtered); // Instantly re-render dynamically
        });
    </script>
</body>
</html>
